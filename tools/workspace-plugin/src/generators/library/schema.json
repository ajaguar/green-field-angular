{
  "$schema": "https://json-schema.org/schema",
  "$id": "library-generator",
  "title": "Create a Library",
  "type": "object",
  "properties": {
    "domain": {
      "type": "string",
      "description": "Select the domain name.",
      "enum": ["chat"],
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "pattern": "chat",
      "x-prompt": {
        "message": "In which domain would you like to generate this library?",
        "type": "list",
        "items": [
          {
            "value": "chat",
            "label": "chat"
          }
        ]
      }
    },
    "type": {
      "type": "string",
      "description": "Select the library type.",
      "enum": ["api", "domain", "feature", "shared", "ui", "util"],
      "x-prompt": {
        "message": "What type of library would you like to generate?",
        "type": "list",
        "items": [
          { "value": "api", "label": "api" },
          { "value": "domain", "label": "domain" },
          { "value": "feature", "label": "feature" },
          { "value": "shared", "label": "shared" },
          { "value": "ui", "label": "ui" },
          { "value": "util", "label": "util" }
        ]
      }
    },
    "name": {
      "type": "string",
      "description": "Name of the library. (Optional)",
      "$default": {
        "$source": "argv",
        "index": 2
      },
      "x-prompt": "What name would you like to use for the library? (Optional)",
      "pattern": "^(?:[a-zA-Z].*)?$"
    },
    "routing": {
      "description": "Add routing to the generated feature library.",
      "type": "boolean",
      "default": false
    }
  },
  "required": ["domain", "type"]
}
