{
  "$schema": "https://json-schema.org/schema",
  "$id": "Domain",
  "title": "",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Enter the domain name.",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "pattern": "^[a-z]+(-[a-z]+)*$",
      "x-prompt": "What name would you like to use for the domain?"
    }
  },
  "required": ["name"]
}
